DATABASE_URL=
JWT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ANTHROPIC_API_KEY=
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Gmail API / Service Account ──────────────────────────────────────────────
# For local dev, leave both empty — the service falls back to
# backend/.secrets/google-sa.json (gitignored).
#
# For Vercel/production, paste the entire JSON content as a single line into
# GOOGLE_SERVICE_ACCOUNT_JSON. (Use GOOGLE_SERVICE_ACCOUNT_PATH only when you
# can mount a key file at a specific path.)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_PATH=
